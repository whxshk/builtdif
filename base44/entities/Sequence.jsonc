{
  "name": "Sequence",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "paused",
        "archived"
      ],
      "default": "draft"
    },
    "project_id": {
      "type": "string"
    },
    "total_enrolled": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name"
  ]
}